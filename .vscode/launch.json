  "version": "0.2.0",
  "configurations": [
    {
      "name": "smlmobilestock",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "web",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d",
        "web-server",
        "--web-port=8080"
      ]
    },

    {
      "name": "smlmobilestock (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "smlmobilestock (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}
